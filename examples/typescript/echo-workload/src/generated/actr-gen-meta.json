{
  "plugin_version": "actr-cli",
  "language": "typescript",
  "local_services": [
    {
      "name": "EchoService",
      "package": "echo",
      "proto_file": "local/echo.proto",
      "handler_interface": "EchoServiceHandler",
      "workload_type": "EchoServiceWorkload",
      "dispatcher_type": "EchoServiceDispatcher",
      "methods": [
        {
          "name": "Echo",
          "snake_name": "echo",
          "route_key": "echo.EchoService.Echo",
          "input_ref": {
            "proto_type": "echo.EchoRequest",
            "type_name": "EchoRequest",
            "proto_package": "echo",
            "proto_file": "local/echo.proto"
          },
          "output_ref": {
            "proto_type": "echo.EchoResponse",
            "type_name": "EchoResponse",
            "proto_package": "echo",
            "proto_file": "local/echo.proto"
          }
        },
        {
          "name": "PrepareStream",
          "snake_name": "prepare_stream",
          "route_key": "echo.EchoService.PrepareStream",
          "input_ref": {
            "proto_type": "echo.StreamPrepareRequest",
            "type_name": "StreamPrepareRequest",
            "proto_package": "echo",
            "proto_file": "local/echo.proto"
          },
          "output_ref": {
            "proto_type": "echo.StreamPrepareResponse",
            "type_name": "StreamPrepareResponse",
            "proto_package": "echo",
            "proto_file": "local/echo.proto"
          }
        },
        {
          "name": "ReleaseStream",
          "snake_name": "release_stream",
          "route_key": "echo.EchoService.ReleaseStream",
          "input_ref": {
            "proto_type": "echo.StreamReleaseRequest",
            "type_name": "StreamReleaseRequest",
            "proto_package": "echo",
            "proto_file": "local/echo.proto"
          },
          "output_ref": {
            "proto_type": "echo.StreamReleaseResponse",
            "type_name": "StreamReleaseResponse",
            "proto_package": "echo",
            "proto_file": "local/echo.proto"
          }
        }
      ]
    }
  ],
  "remote_services": []
}
