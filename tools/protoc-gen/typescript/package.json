{
  "name": "framework-codegen-typescript",
  "version": "0.4.16",
  "private": true,
  "description": "TypeScript protoc plugin for Actor-RTC framework",
  "bin": {
    "protoc-gen-actrframework-typescript": "scripts/protoc-gen-actrframework-typescript"
  },
  "scripts": {
    "build": "tsc",
    "bundle": "esbuild src/main.ts --bundle --platform=node --target=node20 --outfile=dist/bundle.js",
    "check": "tsc --noEmit",
    "test": "npm run bundle && node --test tests/*.test.mjs"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@bufbuild/protobuf": "^2.11.0",
    "@bufbuild/protoplugin": "^2.11.0",
    "typescript": "^5.6.3"
  },
  "devDependencies": {
    "@bufbuild/protoc-gen-es": "^2.11.0",
    "@types/node": "^25.3.2",
    "esbuild": "^0.27.3"
  }
}
