edition = 1
exports = ["protos/local/echo.proto"]

[package]
name = "EchoService"
manufacturer = "{{MANUFACTURER}}"
version = "1.0.0"
description = "Actor-RTC Swift EchoService provider"
authors = ["Actr-Team"]
license = "Apache-2.0"
tags = ["dev", "service"]

[system.signaling]
url = "{{{SIGNALING_URL}}}/signaling/ws"

[system.ais_endpoint]
url = "{{{AIS_ENDPOINT_URL}}}"

[system.deployment]
realm_id = {{REALM_ID}}

[system.discovery]
visible = true

[system.observability]
filter_level = "debug"
tracing_enabled = true
tracing_endpoint = "http://127.0.0.1:4317"
tracing_service_name = "{{PROJECT_NAME}}"

[system.webrtc]
force_relay = false
stun_urls = {{{STUN_URLS}}}
turn_urls = {{{TURN_URLS}}}

[scripts]
dev = "xcodegen generate"
test = "xcodebuild test"

[acl]

[[acl.rules]]
permission = "allow"
type = "{{MANUFACTURER}}:echo-client-app:1.0.0"
