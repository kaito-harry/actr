edition = 1
exports = []

[package]
name = "echo-client-app"
manufacturer = "{{MANUFACTURER}}"
version = "1.0.0"
description = "Echo client app"
authors = ["Actr-Team"]
license = "Apache-2.0"
tags = ["dev", "client"]

[dependencies]
{{#if IS_BOTH}}
EchoService = {}
{{else}}
EchoService = { actr_type = "{{MANUFACTURER}}:EchoService:1.0.0" }
{{/if}}

[system.signaling]
url = "{{{SIGNALING_URL}}}/signaling/ws"

[system.ais_endpoint]
url = "{{{AIS_ENDPOINT_URL}}}"

[system.deployment]
realm_id = {{REALM_ID}}

[system.discovery]
visible = true

[system.observability]
filter_level = "debug"
tracing_enabled = true
tracing_endpoint = "http://127.0.0.1:4317"
tracing_service_name = "{{PROJECT_NAME}}"

[system.webrtc]
force_relay = false
stun_urls = {{{STUN_URLS}}}
turn_urls = {{{TURN_URLS}}}

[scripts]
dev = "xcodegen generate"
test = "xcodebuild test"

[acl]

[[acl.rules]]
permission = "allow"
type = "{{MANUFACTURER}}:EchoService:1.0.0"
