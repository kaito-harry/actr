{
  "name": "@actrium/actr-workload",
  "version": "0.4.14",
  "description": "TypeScript workload authoring and component build tools for ACTR",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "actr-workload-ts": "dist/cli.js"
  },
  "files": [
    "dist",
    "src/wit/actr-workload.wit"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && node -e \"require('node:fs').cpSync('src/wit', 'dist/wit', { recursive: true })\"",
    "check": "tsc -p tsconfig.json --noEmit",
    "format": "prettier --check .",
    "format:write": "prettier --write .",
    "lint": "eslint .",
    "test": "vitest run"
  },
  "dependencies": {
    "@bytecodealliance/componentize-js": "0.21.0",
    "@bytecodealliance/jco": "1.19.0",
    "esbuild": "^0.25.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.22.0",
    "@types/node": "^22.0.0",
    "eslint": "^9.22.0",
    "globals": "^16.0.0",
    "prettier": "^3.5.3",
    "typescript": "^5.3.0",
    "typescript-eslint": "^8.26.1",
    "vitest": "^1.6.1"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Actrium/actr.git",
    "directory": "bindings/typescript/actr-workload"
  },
  "keywords": [
    "actor",
    "component-model",
    "typescript",
    "wasi",
    "workload"
  ],
  "author": "Actor-RTC Contributors",
  "license": "Apache-2.0",
  "publishConfig": {
    "access": "public"
  }
}
